# Deploy Test — environment variables.
# Copy to .env and fill in.

# =============================================================================
# REQUIRED
# =============================================================================

# Postgres connection string. Format: postgresql://user:pass@host:port/db
# Works with any Postgres; no extensions required for this PoC.
# On Cloudflare Workers: replaced by the POSTGRES Hyperdrive binding, leave
# this variable unset on that platform.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deploy_test

# Session / cookie encryption secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-random-string

# =============================================================================
# ADMIN BOOTSTRAP
# =============================================================================

# Comma-separated emails. When a sign-up lands any email in this list, that
# user is promoted to role=admin on creation. No seed account and no default
# credentials — you become admin by registering with an email you control.
#
# Default is `admin@local` so the PoC is usable out of the box; REPLACE THIS
# with your own email before sharing the deploy URL. Example:
#   SYSTEM_ADMIN_EMAILS=you@example.com,ops@example.com
SYSTEM_ADMIN_EMAILS=admin@admin.local

# =============================================================================
# OPTIONAL — Sign-in methods
# =============================================================================
# Neither required. If no OAuth is configured, email+password login is
# auto-enabled so the install is never locked out.

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Force-toggle email login. Defaults to: on iff no OAuth is configured.
# AUTH_EMAIL_ENABLED=
